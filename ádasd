            ],
             "Nấm Âm đạo": [
                
                {name: "For Girl", sl: "01 chai", cd: "Vệ sinh âm đạo ngày 2-3 lần"}
            ]
        },
        consultCatalog: [
            "Gastrozym x 40 gói - Ngày uống 4 gói, chia 2 lần", "Cíc-zinc x 120 viên - Ngày uống 2 viên, chia 2 lần", "Pro HC (Glutathion) x 60 viên - Ngày uống 1 viên", "Fic-P450 (Silymarin 200mg + cà gai leo 100mg) x 60 viên - Ngày uống 4 viên, chia 2 lần", "K2D Bon x 40 viên - Ngày uống 2 viên, chia 2 lần", "Factor-X (Curcumin 200mg, thymomodulin 80mg) x 60 viên - Ngày uống 2 viên, chia 2 lần", "Zibifer x 40 ống - Ngày uống 2 ống, chia 2 lần", "Amino x 40 gói - Ngày uống 2 gói, chia 2 lần", "Gl-Plus (Glutathion 250mg, Beta glucan, alpha lipid) x 30 viên - Ngày uống 1 viên", "Pycno-T x 60 viên (thuốc chống Oxy hóa) - Ngày uống 2 viên, chia 2 lần", "Factor-F Sure 20g x 30 gói - Ngày uống 3 gói, chia 3 lần", "Tyrod (L-Tyrosine 400mg) x 40 viên - Uống ngày 2 viên, chia 2 lần", "Supvid3 x 1 ống - Uống 1 lọ mỗi 6 tháng", "Uro care x 60 viên - Uống ngày 4 viên, chia 2 lần", "Taller bone (Canci, magnesi, kẽm..) x 30 viên - Uống ngày 2 viên chia sáng - chiều"
        ],
        consultTemplates: {
            "Dan do Xa tri": [
                {name: "Vệ sinh vùng da chiếu xạ nhẹ nhàng", sl: "", cd: "Không kỳ cọ mạnh"},
                {name: "Ăn uống đủ chất dinh dưỡng", sl: "", cd: "Tăng cường đạm, vitamin"}
            ]
        }
    };
    // --- STATE QUẢN LÝ ---
    let currentMode = 'thuoc'; // 'thuoc', 'tuvan', 'note'
    const DEFAULT_NOTE_CONTENT = "1. Kê Morphine về2. Làm giấy chuyển tuyến 3. Các luật ở phòng khám cần nhớ";
    
    // Dữ liệu riêng biệt
    let dataStore = {
        thuoc: {
            items: [], 
            catalog: JSON.parse(localStorage.getItem('myMedCatalog')) || HARDCODED_DATA.medCatalog,
            templates: JSON.parse(localStorage.getItem('myMedTemplates')) || HARDCODED_DATA.medTemplates
        },
        tuvan: {
            items: [],
            catalog: JSON.parse(localStorage.getItem('myConsultCatalog')) || HARDCODED_DATA.consultCatalog,
            templates: JSON.parse(localStorage.getItem('myConsultTemplates')) || HARDCODED_DATA.consultTemplates
        }
    };

    // --- KHỞI TẠO ---
    function init() {
        // Load ghi chú từ LocalStorage
        let savedNote = localStorage.getItem('myPersonalNote');
        if (savedNote === null) {
            savedNote = DEFAULT_NOTE_CONTENT;
        }
        document.getElementById('my-note-area').value = savedNote;

        switchMode('thuoc'); // Mặc định vào tab thuốc
    }

    // --- CHUYỂN ĐỔI TAB ---
    function switchMode(mode) {
        currentMode = mode;
        document.body.setAttribute('data-mode', mode);

        // Update Tab Active State
        document.getElementById('tab-thuoc').className = `tab-btn ${mode === 'thuoc' ? 'active-thuoc' : ''}`;
        document.getElementById('tab-tuvan').className = `tab-btn ${mode === 'tuvan' ? 'active-tuvan' : ''}`;
        document.getElementById('tab-note').className  = `tab-btn ${mode === 'note' ? 'active-note' : ''}`;

        // Quản lý hiển thị các vùng làm việc
        const medicalWorkspace = document.getElementById('medical-workspace');
        const noteWorkspace = document.getElementById('note-workspace');
        const mainToolbar = document.getElementById('main-toolbar');

        if (mode === 'note') {
            // Vào chế độ Note
            medicalWorkspace.style.display = 'none';
            noteWorkspace.style.display = 'flex';
            mainToolbar.style.display = 'none'; // Ẩn toolbar in ấn khi đang note
        } else {
            // Vào chế độ Y tế (Thuốc/Tư vấn)
            medicalWorkspace.style.display = 'flex';
            noteWorkspace.style.display = 'none';
            mainToolbar.style.display = 'flex';
            
            // Cập nhật Labels & Placeholders cho Y tế
            if (mode === 'thuoc') {
                document.getElementById('lbl-kho').innerText = "2. Kho thuốc & Kê đơn";
                document.getElementById('lbl-sidebar-title').innerText = "💊 Đơn thuốc đang kê";
                document.getElementById('ui_item_name').placeholder = "Tên thuốc...";
                document.getElementById('ui_item_sl').placeholder = "SL";
                document.getElementById('ui_item_cd').placeholder = "Cách dùng...";
            } else {
                document.getElementById('lbl-kho').innerText = "2. Đơn tư vấn";
                document.getElementById('lbl-sidebar-title').innerText = "📋 Phiếu Tư Vấn đang soạn";
                document.getElementById('ui_item_name').placeholder = "Nội dung dặn dò...";
                document.getElementById('ui_item_sl').placeholder = "Số lượng (nếu có)";
                document.getElementById('ui_item_cd').placeholder = "Ghi chú chi tiết...";
            }
            renderCatalog();
            renderTemplates();
            renderSidebar();
        }
    }

    // --- LOGIC GHI CHÚ (MỚI) ---
    function saveMyNote() {
        const content = document.getElementById('my-note-area').value;
        localStorage.setItem('myPersonalNote', content);
        alert("Đã lưu ghi chú thành công!");
    }

    // --- RENDER GIAO DIỆN Y TẾ ---
    function renderCatalog() {
        const list = dataStore[currentMode].catalog;
        const div = document.getElementById('catalog-grid');
        div.innerHTML = list.map(m => `
            <div class="grid-item" onclick="selectItem('${m}')" title="${m}">
                ${m} <span class="del-btn" onclick="event.stopPropagation(); deleteFromCatalog('${m}')">✖</span>
            </div>
        `).join('');
    }

    function renderTemplates() {
        const temps = dataStore[currentMode].templates;
        const div = document.getElementById('template-grid');
        div.innerHTML = Object.keys(temps).map(name => `
            <div class="grid-item" onclick="loadTemplate('${name}')" style="background:#e8eaf6; color:#1a237e; font-weight:bold;">
                📂 ${name} <span class="del-btn" onclick="event.stopPropagation(); deleteTemplate('${name}')">✖</span>
            </div>
        `).join('');
    }

    function renderSidebar() {
        const items = dataStore[currentMode].items;
        const container = document.getElementById('sidebar-list');
        document.getElementById('count-item').innerText = items.length + " mục";

        if(items.length === 0) {
            container.innerHTML = '<div style="text-align: center; color: #999; margin-top: 20px;">Trống</div>';
            return;
        }

        container.innerHTML = items.map((m, i) => `
            <div class="med-card">
                <div class="med-header">
                    <span class="med-name-disp">${i+1}. ${m.name}</span>
                    <span class="btn-del-mini" onclick="removeItem(${i})">✖</span>
                </div>
                <div class="med-inputs-row">
                    <input class="med-inp-sl" value="${m.sl}" placeholder="SL" onchange="updateItem(${i}, 'sl', this.value)">
                    <input class="med-inp-cd" value="${m.cd}" placeholder="Chi tiết..." onchange="updateItem(${i}, 'cd', this.value)">
                </div>
                <div style="margin-top:2px;">
                    <input style="font-size:11px; padding:2px; color:#555; border:none; background:transparent; width:100%" 
                           value="${m.name}" placeholder="Sửa nội dung..." onchange="updateItem(${i}, 'name', this.value)">
                </div>
            </div>
        `).join('');
    }

    // --- LOGIC THÊM SỬA XÓA ---
    function selectItem(name) {
        document.getElementById('ui_item_name').value = name;
        document.getElementById('ui_item_sl').focus();
    }

    function addItem() {
        let name = document.getElementById('ui_item_name').value;
        let sl = document.getElementById('ui_item_sl').value;
        let cd = document.getElementById('ui_item_cd').value;
        
        if (name) {
            dataStore[currentMode].items.push({ name, sl, cd });
            renderSidebar();
            // Reset input
            document.getElementById('ui_item_name').value = '';
            document.getElementById('ui_item_sl').value = '';
            document.getElementById('ui_item_cd').value = '';
            document.getElementById('ui_item_name').focus();
        }
    }

    function updateItem(index, field, value) {
        dataStore[currentMode].items[index][field] = value;
    }

    function removeItem(index) {
        dataStore[currentMode].items.splice(index, 1);
        renderSidebar();
    }

    // --- LOGIC LƯU TRỮ (Local Storage) ---
    function saveToCatalog() {
        let val = document.getElementById('ui_item_name').value;
        let list = dataStore[currentMode].catalog;
        if (val && !list.includes(val)) {
            list.push(val);
            saveDataToLocal();
            renderCatalog();
        }
    }

    function deleteFromCatalog(val) {
        if(confirm('Xóa khỏi kho: ' + val + '?')) {
            dataStore[currentMode].catalog = dataStore[currentMode].catalog.filter(i => i !== val);
            saveDataToLocal();
            renderCatalog();
        }
    }

    function saveTemplate() {
        let name = prompt("Đặt tên Mẫu:", document.getElementById('ui_chandoan').value);
        if (name) {
            dataStore[currentMode].templates[name] = JSON.parse(JSON.stringify(dataStore[currentMode].items));
            saveDataToLocal();
            renderTemplates();
        }
    }

    function loadTemplate(name) {
        if(confirm("Load mẫu [" + name + "]? List hiện tại sẽ bị xóa.")) {
            dataStore[currentMode].items = JSON.parse(JSON.stringify(dataStore[currentMode].templates[name]));
            renderSidebar();
        }
    }

    function deleteTemplate(name) {
        if(confirm("Xóa mẫu: " + name + "?")) {
            delete dataStore[currentMode].templates[name];
            saveDataToLocal();
            renderTemplates();
        }
    }

    function saveDataToLocal() {
        if (currentMode === 'thuoc') {
            localStorage.setItem('myMedCatalog', JSON.stringify(dataStore.thuoc.catalog));
            localStorage.setItem('myMedTemplates', JSON.stringify(dataStore.thuoc.templates));
        } else if (currentMode === 'tuvan') {
            localStorage.setItem('myConsultCatalog', JSON.stringify(dataStore.tuvan.catalog));
            localStorage.setItem('myConsultTemplates', JSON.stringify(dataStore.tuvan.templates));
        }
    }

    function refreshCurrent() {
        if(confirm("Làm mới tab hiện tại?")) {
            dataStore[currentMode].items = [];
            renderSidebar();
            document.getElementById('ui_item_name').value = '';
            document.getElementById('ui_item_sl').value = '';
            document.getElementById('ui_item_cd').value = '';
        }
    }

    // --- XỬ LÝ IN ẤN ---
    function preparePrintHtml() {
        // Lấy thông tin chung
        const ten = document.getElementById('ui_ten').value || "..........................................";
        const namsinh = document.getElementById('ui_namsinh').value || "...........";
        const gioi = document.getElementById('ui_gioi').value || "...........";
        const diachi = document.getElementById('ui_diachi').value || ".............................................................";
        const chandoan = document.getElementById('ui_chandoan').value || ".............................................................";
        const items = dataStore[currentMode].items;
        
        const d = new Date();
        const dateStr = `Ngày ${d.getDate()} tháng ${d.getMonth() + 1} năm ${d.getFullYear()}`;

        let html = '';

        if (currentMode === 'thuoc') {
            // === LAYOUT ĐƠN THUỐC ===
            html += `
            <div class="print-mode-thuoc">
               <table class="header-table">
            <tr>
                <td class="logo-box">
                    <img id="hospital-logo" src="data:image/webp;base64," alt="Logo">
                </td>
                        <td class="hospital-info">
                            <div class="bold uppercase">BỆNH VIỆN UNG BƯỚU NGHỆ AN</div>
                            <div>Địa chỉ: Km456, Quốc lộ 1, Vinh Hưng, Nghệ An</div>
                            <div>Điện thoại: .......................................</div>
                        </td>
                    </tr>
                </table>
                <div class="prescription-title">ĐƠN THUỐC</div>
            `;
        } else {
            // === LAYOUT ĐƠN TƯ VẤN ===
            html += `
            <div class="print-mode-tuvan">
                <div class="empty-lines"></div>
                <div class="prescription-title">ĐƠN TƯ VẤN</div>
            `;
        }

        // PHẦN THÔNG TIN BỆNH NHÂN
        html += `
                <div class="patient-info-section">
                    <div class="row-txt">
                        <span>Họ tên: <span class="bold uppercase">${ten}</span></span>
                        <span>Số CCCD: ..............................</span>
                    </div>
                    <div>Năm sinh: <span>${namsinh}</span> &nbsp;&nbsp;&nbsp;&nbsp; Giới tính: <span>${gioi}</span></div>
                    <div>Mã số thẻ BHYT: ..........................................................................</div>
                    <div>Nơi thường trú: <span>${diachi}</span></div>
                    <div>Chẩn đoán: <span>${chandoan}</span></div>
                    <div class="bold" style="margin-top: 5px;">${currentMode === 'thuoc' ? 'Thuốc điều trị:' : 'Đơn tư vấn:'}</div>
                </div>
        `;

        // BẢNG ITEM
        html += `<table id="bangThuocPrint">`;
        items.forEach((m, i) => {
            let slText = m.sl ? `SL: ${m.sl}` : '';
            html += `<tr>
                <td style="width:25px; font-weight:bold;">${i+1}.</td>
                <td class="bold">${m.name}</td>
                <td style="text-align:right">${slText}</td>
            </tr>`;
            if(m.cd) {
                html += `<tr><td></td><td colspan="2" class="italic" style="padding-left: 5px;">${m.cd}</td></tr>`;
            }
        });
        html += `</table>`;

        // FOOTER
        html += `<div class="footer-container">`;
        
        if (currentMode === 'thuoc') {
            html += `
            <table class="footer-table">
                <tr>
                    <td style="width: 50%;" class="italic">
                        Lời dặn: ...........................................<br>
                        ...........................................................
                    </td>
                    <td style="text-align: center;">
                        ${dateStr}<br>
                        <span class="bold">Bác sĩ điều trị</span><br>
                        <div style="height: 45px;"></div>
                        <span class="bold">BsCK1. Nguyễn Văn Tiến</span><br>
                        Sđt: 0968.109.523
                    </td>
                </tr>
                <tr>
                    <td colspan="2" class="italic small-footer" style="padding-top: 5px; border-top: 1px dotted #ccc; font-size: 13px;">
                        - Khám lại xin mang theo đơn này.<br>
                        - Họ tên bố mẹ (nếu bệnh nhân là trẻ em): ............................................
                    </td>
                </tr>
            </table>
            `;
        } else {
            html += `
            <div class="footer-tuvan-layout">
                ${dateStr}<br>
                <span class="bold">Bác sĩ khám bệnh</span><br>
                <div style="height: 50px;"></div> <span class="bold">BSCK1. Nguyễn Văn Tiến</span><br>
                Sđt: 0968.109.523
            </div>
            `;
        }

        html += `</div></div>`; // Close wrapper
        
        document.getElementById('print-page-content').innerHTML = html;
    }

    function printPage() {
        preparePrintHtml();
        window.print();
    }

    function downloadPDF() {
        preparePrintHtml();
        let ten = document.getElementById('ui_ten').value || "BN";
        let type = currentMode === 'thuoc' ? "DonThuoc" : "TuVan";
        let d = new Date();
        let dateStr = d.getFullYear() + String(d.getMonth()+1).padStart(2,'0') + String(d.getDate()).padStart(2,'0');
        
        const element = document.getElementById('print-page-content');
        const opt = {
            margin: 0,
            filename: `${dateStr}_${type}_${ten}.pdf`,
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2, useCORS: true },
            jsPDF: { unit: 'mm', format: 'a5', orientation: 'portrait' }
        };
        html2pdf().set(opt).from(element).save();
    }

    function exportDataForFile() {
        const data = {
            medCatalog: dataStore.thuoc.catalog,
            medTemplates: dataStore.thuoc.templates,
            consultCatalog: dataStore.tuvan.catalog,
            consultTemplates: dataStore.tuvan.templates
        };
        const jsonString = JSON.stringify(data, null, 4);
        const codeBlock = `const HARDCODED_DATA = ${jsonString};`;
        
        // Tạo textarea tạm để copy
        const el = document.createElement('textarea');
        el.value = codeBlock;
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        alert("Đã COPY dữ liệu! Hãy dán đè vào biến HARDCODED_DATA trong code.");
    }

    // Phím tắt Enter
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && e.target.tagName === 'INPUT') {
             if (e.target.id === 'ui_item_cd') addItem();
             else if (e.target.id === 'ui_item_sl') document.getElementById('ui_item_cd').focus();
             else if (e.target.id === 'ui_item_name') document.getElementById('ui_item_sl').focus();
        }
    });

    init();
</script>
</body>
</html>
