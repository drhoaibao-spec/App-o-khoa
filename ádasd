    // --- DỮ LIỆU BAN ĐẦU ---
const HARDCODED_DATA = {
        medCatalog: ["Combilipid 1920 ml", "Mg Tan 384 ml", "Levotop (Levofloxacin 500mg)", "Taromentin (Amoxicilin 1g + Clavulanic Acid 62.5mg)", "Macrolacin 500 (Clarithromycin)", "Apfu (Cefodoxim 200mg)", "Cefpar 2g (Cefoperazol 1g +  Sulbactam 1g)"],
